{
    "version": "1.0",
    "controls": [
        {
            "type": "Panel",
            "id": "mainPanel",
            "rect": { "x": 0, "y": 0, "w": 800, "h": 640 },
            "colors": {
                "background": { "normal": "#282828FF" }
            },
            "children": [
                {
                    "type": "MenuBar",
                    "id": "mainMenuBar",
                    "font": { "size": 16 },
                    "menus": [
                        {
                            "caption": "文件(F)",
                            "items": [
                                { "caption": "新建", "shortcut": "Ctrl+N", "events": { "onClick": "onMenuNew" } },
                                { "caption": "打开", "shortcut": "Ctrl+O", "events": { "onClick": "onMenuOpen" } },
                                { "type": "Separator" },
                                {
                                    "caption": "最近文件",
                                    "items": [
                                        { "caption": "file1.txt", "events": { "onClick": "onMenuRecent" } },
                                        { "caption": "file2.txt", "events": { "onClick": "onMenuRecent" } }
                                    ]
                                },
                                { "type": "Separator" },
                                { "caption": "退出", "shortcut": "Alt+F4", "events": { "onClick": "onMenuExit" } }
                            ]
                        },
                        {
                            "caption": "编辑(E)",
                            "items": [
                                { "caption": "撤销", "shortcut": "Ctrl+Z", "events": { "onClick": "onMenuUndo" } },
                                { "caption": "重做", "shortcut": "Ctrl+Y", "events": { "onClick": "onMenuRedo" } }
                            ]
                        },
                        {
                            "caption": "帮助(H)",
                            "items": [
                                { "caption": "关于", "events": { "onClick": "onMenuAbout" } }
                            ]
                        }
                    ]
                },
                {
                    "type": "Label",
                    "id": "titleLabel",
                    "rect": { "x": 0, "y": 52, "w": 800, "h": 40 },
                    "caption": "Layout Configuration Test",
                    "alignment": "CENTER",
                    "font": {
                        "name": "HarmonyOS_Sans_SC_Regular",
                        "size": 28
                    },
                    "colors": {
                        "text": { "normal": "#FFFFFFFF" }
                    },
                    "shadow": {
                        "enabled": true,
                        "offset": { "x": 2, "y": 2 }
                    }
                },
                {
                    "type": "Panel",
                    "id": "formPanel",
                    "rect": { "x": 50, "y": 112, "w": 400, "h": 200 },
                    "colors": {
                        "border": { "normal": "#808080FF" }
                    },
                    "children": [
                        {
                            "type": "Label",
                            "id": "nameLabel",
                            "rect": { "x": 20, "y": 20, "w": 80, "h": 30 },
                            "caption": "Name:",
                            "alignment": "MID_LEFT",
                            "font": { "size": 16 },
                            "colors": {
                                "text": { "normal": "#FFFFFFFF" }
                            }
                        },
                        {
                            "type": "EditBox",
                            "id": "nameEdit",
                            "rect": { "x": 110, "y": 20, "w": 250, "h": 30 },
                            "placeholder": "Please input your name",
                            "font": { "size": 16 },
                            "colors": {
                                "background": { "normal": "#404040FF" },
                                "border": { "normal": "#606060FF" }
                            }
                        },
                        {
                            "type": "Label",
                            "id": "descLabel",
                            "rect": { "x": 20, "y": 70, "w": 360, "h": 20 },
                            "caption": "Type in the edit box above and click Submit",
                            "alignment": "TOP_LEFT",
                            "font": { "size": 12 },
                            "colors": {
                                "text": { "normal": "#A0A0A0FF" }
                            }
                        },
                        {
                            "type": "Button",
                            "id": "submitBtn",
                            "rect": { "x": 280, "y": 140, "w": 100, "h": 35 },
                            "caption": "Submit",
                            "captionSize": 16,
                            "colors": {
                                "background": {
                                    "normal": "#4060A0FF",
                                    "hover": "#5080C0FF",
                                    "pressed": "#305090FF"
                                },
                                "border": { "normal": "#6080C0FF" },
                                "text": { "normal": "#FFFFFFFF" }
                            },
                            "events": {
                                "onClick": "onSubmitClick"
                            }
                        }
                    ]
                },
                {
                    "type": "Panel",
                    "id": "previewPanel",
                    "rect": { "x": 500, "y": 112, "w": 250, "h": 200 },
                    "colors": {
                        "border": { "normal": "#808080FF" }
                    },
                    "children": [
                        {
                            "type": "Label",
                            "id": "previewTitle",
                            "rect": { "x": 10, "y": 10, "w": 230, "h": 25 },
                            "caption": "Preview Panel",
                            "alignment": "CENTER",
                            "font": { "size": 14 },
                            "colors": {
                                "text": { "normal": "#FFFFFFFF" },
                                "border": { "normal": "#606060FF" }
                            },
                            "shadow": { "enabled": false }
                        },
                        {
                            "type": "Label",
                            "id": "previewContent",
                            "rect": { "x": 10, "y": 45, "w": 230, "h": 140 },
                            "caption": "Name:\nAge:\nNotes:",
                            "alignment": "TOP_LEFT",
                            "font": { "size": 14 },
                            "colors": {
                                "text": { "normal": "#C0C0C0FF" }
                            }
                        }
                    ]
                },
                {
                    "type": "Label",
                    "id": "statusLabel",
                    "rect": { "x": 0, "y": 592, "w": 800, "h": 25 },
                    "caption": "Status: Ready",
                    "alignment": "TOP_LEFT",
                    "font": { "size": 14 },
                    "colors": {
                        "text": { "normal": "#808080FF" }
                    }
                },
                {
                    "type": "Label",
                    "id": "colorTestLabel",
                    "rect": { "x": 50, "y": 352, "w": 200, "h": 30 },
                    "caption": "Object format color",
                    "alignment": "MID_LEFT",
                    "font": { "size": 14 },
                    "colors": {
                        "text": { "normal": { "r": 255, "g": 255, "b": 0, "a": 255 } },
                        "border": { "normal": { "r": 0, "g": 255, "b": 255, "a": 255 } }
                    }
                },
                {
                    "type": "Label",
                    "id": "scaledLabel",
                    "rect": { "x": 400, "y": 352, "w": 100, "h": 30 },
                    "scale": { "x": 2.0, "y": 2.0 },
                    "caption": "2x Scaled",
                    "alignment": "CENTER",
                    "font": { "size": 14 },
                    "colors": {
                        "text": { "normal": "#FF8800FF" }
                    },
                    "shadow": {
                        "enabled": true,
                        "offset": { "x": 1, "y": 1 }
                    }
                },
                {
                    "type": "Label",
                    "id": "phase2Title",
                    "rect": { "x": 0, "y": 402, "w": 800, "h": 25 },
                    "caption": "--- Phase 2 Controls ---",
                    "alignment": "CENTER",
                    "font": { "size": 14, "style": "BOLD" },
                    "colors": {
                        "text": { "normal": "#AAAAAAFF" }
                    }
                },
                {
                    "type": "TextArea",
                    "id": "notesTextArea",
                    "rect": { "x": 20, "y": 432, "w": 200, "h": 80 },
                    "placeholder": "Multi-line notes...",
                    "wordWrap": true,
                    "font": { "size": 12 },
                    "colors": {
                        "background": { "normal": "#353535FF" },
                        "border": { "normal": "#606060FF" }
                    },
                    "events": {
                        "onTextChanged": "onNotesChanged"
                    }
                },
                {
                    "type": "CheckBox",
                    "id": "agreeCheck",
                    "rect": { "x": 240, "y": 432, "w": 180, "h": 30 },
                    "caption": "I agree",
                    "captionSize": 14,
                    "checkState": "Unchecked",
                    "style": "Classic",
                    "layout": "TextRight",
                    "events": {
                        "onCheckChanged": "onAgreeChanged"
                    }
                },
                {
                    "type": "CheckBox",
                    "id": "optionCheck",
                    "rect": { "x": 240, "y": 462, "w": 180, "h": 30 },
                    "caption": "Enable option",
                    "captionSize": 14,
                    "checkState": "Checked",
                    "style": "Cross",
                    "layout": "TextRight"
                },
                {
                    "type": "ProgressBar",
                    "id": "loadProgress",
                    "rect": { "x": 440, "y": 432, "w": 200, "h": 25 },
                    "value": 65,
                    "range": { "min": 0, "max": 100 },
                    "style": "Horizontal",
                    "textMode": "Percent",
                    "colors": {
                        "progressColor": "#4080C0FF",
                        "backgroundColor": "#303030FF"
                    }
                },
                {
                    "type": "ProgressBar",
                    "id": "vertProgress",
                    "rect": { "x": 660, "y": 432, "w": 20, "h": 80 },
                    "value": 75,
                    "range": { "min": 0, "max": 100 },
                    "style": "Vertical",
                    "textMode": "None",
                    "colors": {
                        "progressColor": "#60C060FF",
                        "backgroundColor": "#303030FF"
                    }
                },
                {
                    "type": "ScrollBar",
                    "id": "hScroll",
                    "rect": { "x": 440, "y": 472, "w": 200, "h": 16 },
                    "orientation": "Horizontal",
                    "value": 30,
                    "range": { "min": 0, "max": 100 },
                    "pageSize": 20,
                    "stepSize": 5
                },
                {
                    "type": "ScrollBar",
                    "id": "vScroll",
                    "rect": { "x": 700, "y": 402, "w": 16, "h": 110 },
                    "orientation": "Vertical",
                    "value": 50,
                    "range": { "min": 0, "max": 200 },
                    "pageSize": 30,
                    "stepSize": 10
                },
                {
                    "type": "Button",
                    "id": "imageBtn",
                    "rect": { "x": 20, "y": 532, "w": 160, "h": 40 },
                    "caption": "Image Button",
                    "captionSize": 14,
                    "actors": {
                        "normal": "assets/images/cross_up.png",
                        "hover": "assets/images/cross_over.png",
                        "pressed": "assets/images/cross_down.png"
                    },
                    "colors": {
                        "background": { "normal": "#505050FF", "hover": "#606060FF", "pressed": "#404040FF" },
                        "text": { "normal": "#FFFFFFFF" }
                    },
                    "events": {
                        "onClick": "onImageBtnClick"
                    }
                },
                {
                    "type": "Button",
                    "id": "aniBtn",
                    "rect": { "x": 200, "y": 532, "w": 100, "h": 40 },
                    "caption": "Animated",
                    "captionSize": 14,
                    "luotiAni": "assets/animations/rotateBtn/rotateBtn.jsonc",
                    "colors": {
                        "background": {
                            "normal": "#505050FF",
                            "hover": "#606060FF",
                            "pressed": "#404040FF"
                        },
                        "text": { "normal": "#FFFFFFFF" }
                    },
                    "events": {
                        "onClick": "onAniBtnClick"
                    }
                },
                {
                    "type": "Button",
                    "id": "captionLabelBtn",
                    "rect": { "x": 320, "y": 532, "w": 120, "h": 40 },
                    "captionLabel": {
                        "caption": "Styled",
                        "font": { "size": 18, "style": "BOLD" },
                        "alignment": "CENTER",
                        "shadow": {
                            "enabled": true,
                            "offset": { "x": 1, "y": 1 }
                        },
                        "colors": {
                            "text": { "normal": "#FFD700FF", "hover": "#FFA500FF", "pressed": "#FF8C00FF" },
                            "textShadow": { "normal": "#00000080" }
                        }
                    },
                    "colors": {
                        "background": {
                            "normal": "#404040FF",
                            "hover": "#505050FF",
                            "pressed": "#303030FF"
                        },
                        "border": { "normal": "#808080FF" }
                    },
                    "events": {
                        "onClick": "onCaptionLabelBtnClick"
                    }
                },
                {
                    "type": "Dialog",
                    "id": "resultDialog",
                    "rect": { "x": 200, "y": 100, "w": 400, "h": 300 },
                    "title": "Submitted",
                    "text": "Form submitted successfully!\n\nThis is a Dialog with TextArea.\n\nThe TextArea has built-in scrollbar support, so long text can be viewed without page-turning buttons.\n\nLine 4\nLine 5\nLine 6\nLine 7\nLine 8\nLine 9\nLine 10\nLine 11\nLine 12\nLine 13\nLine 14\nLine 15\nLine 16\nLine 17\nLine 18\nLine 19\nLine 20",
                    "okBtnCaption": "Close"
                }
            ]
        }
    ]
}
