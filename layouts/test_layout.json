{
    "version": "1.0",
    "controls": [
        {
            "type": "Panel",
            "id": "mainPanel",
            "rect": { "x": 0, "y": 0, "w": 800, "h": 600 },
            "colors": {
                "background": { "normal": "#282828FF" }
            },
            "children": [
                {
                    "type": "Label",
                    "id": "titleLabel",
                    "rect": { "x": 0, "y": 20, "w": 800, "h": 40 },
                    "caption": "Layout Configuration Test",
                    "alignment": "CENTER",
                    "font": {
                        "name": "HarmonyOS_Sans_SC_Regular",
                        "size": 28
                    },
                    "colors": {
                        "text": { "normal": "#FFFFFFFF" }
                    },
                    "shadow": {
                        "enabled": true,
                        "offset": { "x": 2, "y": 2 }
                    }
                },
                {
                    "type": "Panel",
                    "id": "formPanel",
                    "rect": { "x": 50, "y": 80, "w": 400, "h": 200 },
                    "colors": {
                        "border": { "normal": "#808080FF" }
                    },
                    "children": [
                        {
                            "type": "Label",
                            "id": "nameLabel",
                            "rect": { "x": 20, "y": 20, "w": 80, "h": 30 },
                            "caption": "Name:",
                            "alignment": "MID_LEFT",
                            "font": { "size": 16 },
                            "colors": {
                                "text": { "normal": "#FFFFFFFF" }
                            }
                        },
                        {
                            "type": "EditBox",
                            "id": "nameEdit",
                            "rect": { "x": 110, "y": 20, "w": 250, "h": 30 },
                            "placeholder": "Please input your name",
                            "font": { "size": 16 },
                            "colors": {
                                "background": { "normal": "#404040FF" },
                                "border": { "normal": "#606060FF" }
                            }
                        },
                        {
                            "type": "Label",
                            "id": "descLabel",
                            "rect": { "x": 20, "y": 70, "w": 360, "h": 20 },
                            "caption": "Type in the edit box above and click Submit",
                            "alignment": "TOP_LEFT",
                            "font": { "size": 12 },
                            "colors": {
                                "text": { "normal": "#A0A0A0FF" }
                            }
                        },
                        {
                            "type": "Button",
                            "id": "submitBtn",
                            "rect": { "x": 280, "y": 140, "w": 100, "h": 35 },
                            "caption": "Submit",
                            "captionSize": 16,
                            "colors": {
                                "background": {
                                    "normal": "#4060A0FF",
                                    "hover": "#5080C0FF",
                                    "pressed": "#305090FF"
                                },
                                "border": { "normal": "#6080C0FF" },
                                "text": { "normal": "#FFFFFFFF" }
                            },
                            "events": {
                                "onClick": "onSubmitClick"
                            }
                        }
                    ]
                },
                {
                    "type": "Panel",
                    "id": "previewPanel",
                    "rect": { "x": 500, "y": 80, "w": 250, "h": 200 },
                    "colors": {
                        "border": { "normal": "#808080FF" }
                    },
                    "children": [
                        {
                            "type": "Label",
                            "id": "previewTitle",
                            "rect": { "x": 10, "y": 10, "w": 230, "h": 25 },
                            "caption": "Preview Panel",
                            "alignment": "CENTER",
                            "font": { "size": 14 },
                            "colors": {
                                "text": { "normal": "#FFFFFFFF" },
                                "border": { "normal": "#606060FF" }
                            },
                            "shadow": { "enabled": false }
                        },
                        {
                            "type": "Label",
                            "id": "previewContent",
                            "rect": { "x": 10, "y": 45, "w": 230, "h": 140 },
                            "caption": "Name:\nAge:\nNotes:",
                            "alignment": "TOP_LEFT",
                            "font": { "size": 14 },
                            "colors": {
                                "text": { "normal": "#C0C0C0FF" }
                            }
                        }
                    ]
                },
                {
                    "type": "Label",
                    "id": "statusLabel",
                    "rect": { "x": 0, "y": 560, "w": 800, "h": 25 },
                    "caption": "Status: Ready",
                    "alignment": "TOP_LEFT",
                    "font": { "size": 14 },
                    "colors": {
                        "text": { "normal": "#808080FF" }
                    }
                },
                {
                    "type": "Label",
                    "id": "colorTestLabel",
                    "rect": { "x": 50, "y": 320, "w": 200, "h": 30 },
                    "caption": "Object format color",
                    "alignment": "MID_LEFT",
                    "font": { "size": 14 },
                    "colors": {
                        "text": { "normal": { "r": 255, "g": 255, "b": 0, "a": 255 } },
                        "border": { "normal": { "r": 0, "g": 255, "b": 255, "a": 255 } }
                    }
                },
                {
                    "type": "Label",
                    "id": "scaledLabel",
                    "rect": { "x": 400, "y": 320, "w": 100, "h": 30 },
                    "scale": { "x": 2.0, "y": 2.0 },
                    "caption": "2x Scaled",
                    "alignment": "CENTER",
                    "font": { "size": 14 },
                    "colors": {
                        "text": { "normal": "#FF8800FF" }
                    },
                    "shadow": {
                        "enabled": true,
                        "offset": { "x": 1, "y": 1 }
                    }
                },
                {
                    "type": "Label",
                    "id": "phase2Title",
                    "rect": { "x": 0, "y": 370, "w": 800, "h": 25 },
                    "caption": "--- Phase 2 Controls ---",
                    "alignment": "CENTER",
                    "font": { "size": 14, "style": "BOLD" },
                    "colors": {
                        "text": { "normal": "#AAAAAAFF" }
                    }
                },
                {
                    "type": "TextArea",
                    "id": "notesTextArea",
                    "rect": { "x": 20, "y": 400, "w": 200, "h": 80 },
                    "placeholder": "Multi-line notes...",
                    "wordWrap": true,
                    "font": { "size": 12 },
                    "colors": {
                        "background": { "normal": "#353535FF" },
                        "border": { "normal": "#606060FF" }
                    },
                    "events": {
                        "onTextChanged": "onNotesChanged"
                    }
                },
                {
                    "type": "CheckBox",
                    "id": "agreeCheck",
                    "rect": { "x": 240, "y": 400, "w": 180, "h": 30 },
                    "caption": "I agree",
                    "captionSize": 14,
                    "checkState": "Unchecked",
                    "style": "Classic",
                    "layout": "TextRight",
                    "events": {
                        "onCheckChanged": "onAgreeChanged"
                    }
                },
                {
                    "type": "CheckBox",
                    "id": "optionCheck",
                    "rect": { "x": 240, "y": 430, "w": 180, "h": 30 },
                    "caption": "Enable option",
                    "captionSize": 14,
                    "checkState": "Checked",
                    "style": "Cross",
                    "layout": "TextRight"
                },
                {
                    "type": "ProgressBar",
                    "id": "loadProgress",
                    "rect": { "x": 440, "y": 400, "w": 200, "h": 25 },
                    "value": 65,
                    "range": { "min": 0, "max": 100 },
                    "style": "Horizontal",
                    "textMode": "Percent",
                    "colors": {
                        "progressColor": "#4080C0FF",
                        "backgroundColor": "#303030FF"
                    }
                },
                {
                    "type": "ProgressBar",
                    "id": "vertProgress",
                    "rect": { "x": 660, "y": 400, "w": 20, "h": 80 },
                    "value": 75,
                    "range": { "min": 0, "max": 100 },
                    "style": "Vertical",
                    "textMode": "None",
                    "colors": {
                        "progressColor": "#60C060FF",
                        "backgroundColor": "#303030FF"
                    }
                },
                {
                    "type": "ScrollBar",
                    "id": "hScroll",
                    "rect": { "x": 440, "y": 440, "w": 200, "h": 16 },
                    "orientation": "Horizontal",
                    "value": 30,
                    "range": { "min": 0, "max": 100 },
                    "pageSize": 20,
                    "stepSize": 5
                },
                {
                    "type": "ScrollBar",
                    "id": "vScroll",
                    "rect": { "x": 700, "y": 370, "w": 16, "h": 110 },
                    "orientation": "Vertical",
                    "value": 50,
                    "range": { "min": 0, "max": 200 },
                    "pageSize": 30,
                    "stepSize": 10
                }
            ]
        }
    ]
}
